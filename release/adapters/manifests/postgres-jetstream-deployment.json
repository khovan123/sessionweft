{
  "schema_version": 1,
  "adapter_id": "postgres-jetstream-deployment",
  "version": "1.0.0",
  "kind": "deployment",
  "production": true,
  "supported_platforms": ["linux", "macos", "windows"],
  "capabilities": ["postgresql", "jetstream", "outbox_inbox", "multi_runtime"],
  "source_paths": ["crates/sessionweft-service-postgres/src/lib.rs", "crates/sessionweft-jetstream/src/lib.rs", "deploy/docker-compose.service.yml"],
  "required_gates": ["contract", "compatibility", "security", "recovery", "observability", "supply_chain"]
}
