{
  "schema_version": 1,
  "adapter_id": "sqlite-local-deployment",
  "version": "1.0.0",
  "kind": "deployment",
  "production": true,
  "supported_platforms": ["linux", "macos", "windows"],
  "capabilities": ["sqlite_wal", "local_event_transport", "restart_recovery"],
