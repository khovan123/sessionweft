        {"expr": "sessionweft_active_locks", "legendFormat": "Active locks", "refId": "B"}
      ]
    },
    {
      "type": "stat",
      "title": "JetStream Consumers",
      "id": 4,
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 5},
      "targets": [{"expr": "sessionweft_jetstream_consumers", "refId": "A"}]
